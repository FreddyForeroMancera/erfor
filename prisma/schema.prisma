generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  DIRECTOR_AMBIENTAL
  CONSULTOR_AMBIENTAL
  ASISTENTE_ADMINISTRATIVO
  CLIENTE_EXTERNO
  AUDITOR
}

enum Status {
  ACTIVE
  INACTIVE
  PROSPECT
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkStatus {
  DRAFT
  PREPARATION
  FILED
  EVALUATION
  REQUIREMENT
  RESPONDED
  VISIT
  TECHNICAL_CONCEPT
  APPROVED
  DENIED
  SUSPENDED
  ARCHIVED
  COMPLETED
  OVERDUE
  IN_REVIEW
  SENT
}

model User {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  passwordHash      String
  role              Role     @default(CONSULTOR_AMBIENTAL)
  avatar            String?
  status            Status   @default(ACTIVE)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  responsibleProjects Project[] @relation("ProjectResponsible")
  files             EnvironmentalFile[] @relation("FileResponsible")
  procedures        Procedure[] @relation("ProcedureResponsible")
  obligations       EnvironmentalObligation[] @relation("ObligationResponsible")
  requirements      Requirement[] @relation("RequirementResponsible")
  uploadedDocuments Document[] @relation("DocumentUploader")
  assignedTasks     Task[]   @relation("TaskAssignee")
  generatedReports  Report[] @relation("ReportGenerator")
  activityLogs      ActivityLog[]
  conversations     AIConversation[]
}

model Client {
  id             String   @id @default(cuid())
  name           String
  type           String
  documentType   String?
  documentNumber String?
  representative String?
  email          String?
  phone          String?
  address        String?
  city           String?
  department     String?
  contactPerson  String?
  status         Status   @default(ACTIVE)
  priority       Priority @default(MEDIUM)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  projects       Project[]
  properties     Property[]
  files          EnvironmentalFile[]
  procedures     Procedure[]
  permits        Permit[]
  obligations    EnvironmentalObligation[]
  requirements   Requirement[]
  visits         Visit[]
  documents      Document[]
  tasks          Task[]
  alerts         Alert[]
  reports        Report[]
  conversations  AIConversation[]
}

model Project {
  id                     String   @id @default(cuid())
  clientId               String
  name                   String
  type                   String
  description            String?
  activity               String?
  location               String?
  city                   String?
  department             String?
  coordinates            String?
  environmentalAuthority String?
  status                 WorkStatus @default(PREPARATION)
  riskLevel              RiskLevel @default(MEDIUM)
  responsibleUserId      String?
  startDate              DateTime?
  estimatedEndDate       DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  responsible            User?    @relation("ProjectResponsible", fields: [responsibleUserId], references: [id])
  properties             Property[]
  files                  EnvironmentalFile[]
  procedures             Procedure[]
  permits                Permit[]
  obligations            EnvironmentalObligation[]
  requirements           Requirement[]
  visits                 Visit[]
  documents              Document[]
  tasks                  Task[]
  alerts                 Alert[]
  reports                Report[]
  conversations          AIConversation[]
}

model Property {
  id                        String   @id @default(cuid())
  clientId                  String
  projectId                 String?
  name                      String
  cadastralCode             String?
  realEstateRegistration    String?
  owner                     String?
  area                      String?
  useCurrent                String?
  useProposed               String?
  address                   String?
  city                      String?
  department                String?
  village                   String?
  coordinates               String?
  environmentalAuthority    String?
  environmentalRestrictions String?
  waterSourceProximity      String?
  protectedAreas            String?
  notes                     String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  client                    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project                   Project? @relation(fields: [projectId], references: [id])
  files                     EnvironmentalFile[]
  visits                    Visit[]
  documents                 Document[]
}

model EnvironmentalFile {
  id                String   @id @default(cuid())
  clientId          String
  projectId         String?
  propertyId        String?
  internalCode      String
  officialCode      String?
  authority         String
  type              String
  status            WorkStatus @default(PREPARATION)
  priority          Priority @default(MEDIUM)
  riskLevel         RiskLevel @default(MEDIUM)
  openedAt          DateTime?
  filedAt           DateTime?
  nextDeadline      DateTime?
  responsibleUserId String?
  description       String?
  timeline          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project           Project? @relation(fields: [projectId], references: [id])
  property          Property? @relation(fields: [propertyId], references: [id])
  responsible       User?    @relation("FileResponsible", fields: [responsibleUserId], references: [id])
  procedures        Procedure[]
  requirements      Requirement[]
  visits            Visit[]
  documents         Document[]
  tasks             Task[]
  alerts            Alert[]
  conversations     AIConversation[]
}

model Procedure {
  id                  String   @id @default(cuid())
  clientId            String
  projectId           String?
  environmentalFileId String?
  type                String
  authority           String
  status              WorkStatus @default(DRAFT)
  filingNumber        String?
  filingDate          DateTime?
  expectedResponseDate DateTime?
  nextDeadline        DateTime?
  responsibleUserId   String?
  riskLevel           RiskLevel @default(MEDIUM)
  requiredDocuments   String?
  deliveredDocuments  String?
  missingDocuments    String?
  notes               String?
  result              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project             Project? @relation(fields: [projectId], references: [id])
  environmentalFile   EnvironmentalFile? @relation(fields: [environmentalFileId], references: [id])
  responsible         User?    @relation("ProcedureResponsible", fields: [responsibleUserId], references: [id])
  permits             Permit[]
  documents           Document[]
}

model Permit {
  id            String   @id @default(cuid())
  clientId      String
  projectId     String?
  procedureId   String?
  type          String
  authority     String
  status        WorkStatus @default(APPROVED)
  issueDate     DateTime?
  expirationDate DateTime?
  renewalDate   DateTime?
  obligations   String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project       Project? @relation(fields: [projectId], references: [id])
  procedure     Procedure? @relation(fields: [procedureId], references: [id])
  environmentalObligations EnvironmentalObligation[]
}

model LegalRequirement {
  id               String   @id @default(cuid())
  title            String
  normType         String
  normNumber       String?
  year             Int?
  authority        String?
  scope            String
  category         String
  obligationText   String
  appliesTo        String?
  evidenceRequired String?
  responsible      String?
  periodicity      String?
  source           String?
  status           String   @default("PENDING_VALIDATION")
  expertNotes      String?
  verified         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  obligations      EnvironmentalObligation[]
}

model EnvironmentalObligation {
  id                 String   @id @default(cuid())
  clientId           String
  projectId          String?
  permitId           String?
  legalRequirementId String?
  title              String
  description        String?
  category           String
  responsibleUserId  String?
  periodicity        String?
  startDate          DateTime?
  dueDate            DateTime?
  status             String   @default("IN_RISK")
  riskLevel          RiskLevel @default(MEDIUM)
  evidenceRequired   String?
  evidenceLoaded     String?
  nextAction         String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project            Project? @relation(fields: [projectId], references: [id])
  permit             Permit?  @relation(fields: [permitId], references: [id])
  legalRequirement   LegalRequirement? @relation(fields: [legalRequirementId], references: [id])
  responsible        User?    @relation("ObligationResponsible", fields: [responsibleUserId], references: [id])
}

model Requirement {
  id                  String   @id @default(cuid())
  clientId            String
  projectId           String?
  environmentalFileId String?
  authority           String
  filingNumber        String?
  receivedAt          DateTime?
  dueDate             DateTime?
  subject             String
  description         String?
  requestedDocuments  String?
  status              WorkStatus @default(REQUIREMENT)
  priority            Priority @default(HIGH)
  riskLevel           RiskLevel @default(HIGH)
  responsibleUserId   String?
  responseText        String?
  responseSentAt      DateTime?
  notes               String?
  extractedJson       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project             Project? @relation(fields: [projectId], references: [id])
  environmentalFile   EnvironmentalFile? @relation(fields: [environmentalFileId], references: [id])
  responsible         User?    @relation("RequirementResponsible", fields: [responsibleUserId], references: [id])
  documents           Document[]
}

model Visit {
  id                  String   @id @default(cuid())
  clientId            String
  projectId           String?
  propertyId          String?
  environmentalFileId String?
  type                String
  scheduledAt         DateTime?
  completedAt         DateTime?
  attendees           String?
  objective           String?
  findings            String?
  commitments         String?
  coordinates         String?
  status              WorkStatus @default(PREPARATION)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project             Project? @relation(fields: [projectId], references: [id])
  property            Property? @relation(fields: [propertyId], references: [id])
  environmentalFile   EnvironmentalFile? @relation(fields: [environmentalFileId], references: [id])
  documents           Document[]
}

model Document {
  id                  String   @id @default(cuid())
  clientId            String?
  projectId           String?
  propertyId          String?
  environmentalFileId String?
  procedureId         String?
  requirementId       String?
  visitId             String?
  name                String
  fileUrl             String
  fileType            String
  category            String
  version             Int      @default(1)
  status              String   @default("ACTIVE")
  extractedText       String?
  tags                String?
  uploadedBy          String?
  source              String?
  observations        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  client              Client?  @relation(fields: [clientId], references: [id])
  project             Project? @relation(fields: [projectId], references: [id])
  property            Property? @relation(fields: [propertyId], references: [id])
  environmentalFile   EnvironmentalFile? @relation(fields: [environmentalFileId], references: [id])
  procedure           Procedure? @relation(fields: [procedureId], references: [id])
  requirement         Requirement? @relation(fields: [requirementId], references: [id])
  visit               Visit? @relation(fields: [visitId], references: [id])
  uploader            User? @relation("DocumentUploader", fields: [uploadedBy], references: [id])
}

model Task {
  id                  String   @id @default(cuid())
  title               String
  description         String?
  clientId            String?
  projectId           String?
  environmentalFileId String?
  assignedTo          String?
  priority            Priority @default(MEDIUM)
  status              String   @default("OPEN")
  dueDate             DateTime?
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  client              Client? @relation(fields: [clientId], references: [id])
  project             Project? @relation(fields: [projectId], references: [id])
  environmentalFile   EnvironmentalFile? @relation(fields: [environmentalFileId], references: [id])
  assignee            User? @relation("TaskAssignee", fields: [assignedTo], references: [id])
}

model Alert {
  id                String   @id @default(cuid())
  type              String
  title             String
  description       String?
  severity          Priority @default(MEDIUM)
  clientId          String?
  projectId         String?
  environmentalFileId String?
  relatedEntityType String?
  relatedEntityId   String?
  status            String   @default("OPEN")
  dueDate           DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  client            Client? @relation(fields: [clientId], references: [id])
  project           Project? @relation(fields: [projectId], references: [id])
  environmentalFile EnvironmentalFile? @relation(fields: [environmentalFileId], references: [id])
}

model Report {
  id          String   @id @default(cuid())
  clientId    String?
  projectId   String?
  type        String
  title       String
  periodStart DateTime?
  periodEnd   DateTime?
  fileUrl     String?
  generatedBy String?
  generatedAt DateTime @default(now())
  status      String   @default("GENERATED")
  payload     String?
  client      Client? @relation(fields: [clientId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id])
  generator   User? @relation("ReportGenerator", fields: [generatedBy], references: [id])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  description String
  createdAt   DateTime @default(now())
  user        User? @relation(fields: [userId], references: [id])
}

model AIConversation {
  id                  String   @id @default(cuid())
  userId              String
  clientId            String?
  projectId           String?
  environmentalFileId String?
  title               String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User @relation(fields: [userId], references: [id])
  client              Client? @relation(fields: [clientId], references: [id])
  project             Project? @relation(fields: [projectId], references: [id])
  environmentalFile   EnvironmentalFile? @relation(fields: [environmentalFileId], references: [id])
  messages            AIMessage[]
}

model AIMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  sources        String?
  createdAt      DateTime @default(now())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model IntegrationSource {
  id        String   @id @default(cuid())
  name      String
  type      String
  status    String   @default("CONFIGURED")
  config    String?
  lastSync  DateTime?
  errors    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ImportJob {
  id          String   @id @default(cuid())
  type        String
  fileName    String
  status      String   @default("PREVIEW")
  sheetNames  String?
  mapping     String?
  summary     String?
  errors      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Template {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
